apiVersion: apps/v1
kind: Deployment
metadata:
  name: spaceproject-deployment
spec:
  replicas: 2
  selector:
    matchLabels:
      app: space
  template:
    metadata:
      labels:
        app: space
    spec:
      containers:
      - name: s123-container
        image: vasudhara12/vasundhara-nginx-app:latest
        ports:
        - containerPort: 80

---
apiVersion: v1
kind: Service
metadata:
  name: sproject-service
spec:
  type: NodePort
  selector:
    app: space
  ports:
  - port: 80
    targetPort: 80
    nodePort: 31111
